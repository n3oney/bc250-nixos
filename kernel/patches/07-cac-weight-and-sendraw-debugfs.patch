+/*
+ * BC-250 PMFW CAC weight debugfs interface.
+ *
+ * Two read/write files under /sys/kernel/debug/dri/N/:
+ *   cyan_skillfish_gfx_cac_weight   - 64 GFX CAC slots
+ *   cyan_skillfish_l3_cac_weight    - 80 L3  CAC slots
+ *
+ * Read returns the full table, one slot per line:
+ *   "  0: 0x17\n"
+ *   "  1: 0x00\n"
+ *   ...
+ *
+ * Write accepts "<idx> <value>" lines (decimal or hex; whitespace-tolerant):
+ *   echo "0 0x18" > cyan_skillfish_gfx_cac_weight
+ *
+ * Backed by PPSMC_MSG_GfxCacWeightOperation (0x2F) /
+ * PPSMC_MSG_L3CacWeightOperation (0x30). arg = (op<<24) | (idx<<8) | value.
+ * Op 0=read, 1=write, 2=clear.
+ *
+ * Root-only (0600). Intended for BC-250 BAPM tuning experiments.
+ */
+
+#define CYAN_SKILLFISH_GFX_CAC_SLOTS	64
+#define CYAN_SKILLFISH_L3_CAC_SLOTS	80
+
+struct cyan_cac_file_ctx {
+	struct amdgpu_device *adev;
+	uint16_t smu_msg;	/* SMU_MSG_GfxCacWeightOperation or _L3... */
+	uint16_t n_slots;
+};
+
+/*
+ * Empirical PMFW arg encoding for CAC weight msgids on BC-250
+ * (PMFW 88.6.0). Probed on stock PMFW 88.6.0:
+ *   arg = idx  -> PMFW returns current weight in response arg slot
+ * Write encoding is TBD - the verified op-as-msgid pairing is
+ * GfxCacWeightOperation/L3CacWeightOperation = read by default.
+ * Future investigation: PackCoreCacWeight (0x31) may be the write
+ * commit path.
+ */
+static int cyan_cac_read_one(struct smu_context *smu, uint16_t msg,
+			     uint8_t idx, uint32_t *value)
+{
+	return smu_cmn_send_smc_msg_with_param(smu, msg, idx, value);
+}
+
+/*
+ * Write path for CAC weights is currently NOT implemented - the PMFW arg
+ * encoding for writes is not verified, and naive guesses
+ * ((value<<16)|idx, (op<<24)|(idx<<8)|value) return -EIO on BC-250 PMFW
+ * 88.6.0. Use the smu_send_raw debugfs to validate write encodings
+ * experimentally before wiring this up.
+ *
+ * For BAPM-write semantics, PPSMC_MSG_PackCoreCacWeight (0x31) is the
+ * suspected commit-write path; investigate before adding a write hook.
+ */
+
+static ssize_t cyan_cac_read(struct file *f, char __user *ubuf,
+			     size_t count, loff_t *pos)
+{
+	struct cyan_cac_file_ctx *ctx = f->f_inode->i_private;
+	struct smu_context *smu = ctx->adev->powerplay.pp_handle;
+	char *buf;
+	size_t buf_size = ctx->n_slots * 16 + 64;
+	int n = 0, i, ret;
+	ssize_t out;
+
+	if (!smu)
+		return -ENODEV;
+
+	buf = kmalloc(buf_size, GFP_KERNEL);
+	if (!buf)
+		return -ENOMEM;
+
+	for (i = 0; i < ctx->n_slots; i++) {
+		uint32_t value = 0;
+
+		ret = cyan_cac_read_one(smu, ctx->smu_msg, (uint8_t)i, &value);
+		if (ret) {
+			n += scnprintf(buf + n, buf_size - n,
+				       "%3d: ERR %d\n", i, ret);
+		} else {
+			n += scnprintf(buf + n, buf_size - n,
+				       "%3d: 0x%04x\n", i, value & 0xffff);
+		}
+	}
+
+	out = simple_read_from_buffer(ubuf, count, pos, buf, n);
+	kfree(buf);
+	return out;
+}
+
+static const struct file_operations cyan_cac_fops = {
+	.owner = THIS_MODULE,
+	.read = cyan_cac_read,
+	.llseek = default_llseek,
+};
+
+/* file contexts - single-instance is fine for cyan_skillfish */
+static struct cyan_cac_file_ctx cyan_gfx_cac_ctx;
+static struct cyan_cac_file_ctx cyan_l3_cac_ctx;
+
+void cyan_skillfish_create_cac_debugfs(struct amdgpu_device *adev)
+{
+	struct dentry *root;
+
+	if (!adev || adev->asic_type != CHIP_CYAN_SKILLFISH)
+		return;
+	if (!adev->powerplay.pp_handle)
+		return;
+
+	root = adev_to_drm(adev)->primary->debugfs_root;
+	if (!root)
+		return;
+
+	cyan_gfx_cac_ctx.adev = adev;
+	cyan_gfx_cac_ctx.smu_msg = SMU_MSG_GfxCacWeightOperation;
+	cyan_gfx_cac_ctx.n_slots = CYAN_SKILLFISH_GFX_CAC_SLOTS;
+
+	cyan_l3_cac_ctx.adev = adev;
+	cyan_l3_cac_ctx.smu_msg = SMU_MSG_L3CacWeightOperation;
+	cyan_l3_cac_ctx.n_slots = CYAN_SKILLFISH_L3_CAC_SLOTS;
+
+	debugfs_create_file("cyan_skillfish_gfx_cac_weight", S_IRUSR,
+			    root, &cyan_gfx_cac_ctx, &cyan_cac_fops);
+	debugfs_create_file("cyan_skillfish_l3_cac_weight", S_IRUSR,
+			    root, &cyan_l3_cac_ctx, &cyan_cac_fops);
+}
+
+#else  /* !CONFIG_DEBUG_FS */
+void cyan_skillfish_create_cac_debugfs(struct amdgpu_device *adev) { (void)adev; }
+#endif
